# ── LLM ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1           # optional — custom endpoint

# ── Observability (optional) ────────────────────────
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── MCP Server ──────────────────────────────────────
# MCP_HOST=127.0.0.1
# MCP_PORT=8765

# ── Search Providers ────────────────────────────────
# At least one provider must be configured for searches.
# DuckDuckGo is always available (free, no key needed)
# and acts as the final fallback.
#
# Priority order: Tavily → Brave → SerpAPI → SearXNG → DuckDuckGo

# Tavily Search API — https://tavily.com
# TAVILY_API_KEY=tvly-...

# Brave Search API — https://brave.com/search/api/
# BRAVE_API_KEY=BSA...

# SerpAPI Google Search — https://serpapi.com
# SERPAPI_API_KEY=...

# SearXNG self-hosted metasearch — https://searxng.org
# SEARXNG_BASE_URL=http://your-instance:8888
