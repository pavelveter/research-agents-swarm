# ──────────────────────────────────────────────────────────────
# Research Swarm — Environment Configuration
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────

# ── LLM (OpenAI-compatible) ─────────────────────────────────
# Required. Your OpenAI API key, or a compatible provider key.
OPENAI_API_KEY=sk-...

# Optional. Use a custom OpenAI-compatible endpoint (Ollama, Groq, etc.).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Model name. Default: gpt-4o.
# OPENAI_MODEL=gpt-4o


# ── Search Providers (at least one recommended) ──────────────
# DuckDuckGo is always available as a free fallback (no key needed).
# Priority order: Tavily → Brave → SerpAPI → SearXNG → DuckDuckGo.

# Tavily — AI-optimized search. Get key: https://tavily.com
# TAVILY_API_KEY=tvly-...

# Brave Search API. Get key: https://brave.com/search/api/
# BRAVE_API_KEY=BSA...

# SerpAPI — Google Search API. Get key: https://serpapi.com
# SERPAPI_API_KEY=...

# SearXNG — self-hosted metasearch instance URL
# SEARXNG_BASE_URL=http://localhost:8888


# ── Vector Memory (Qdrant + Ollama) ──────────────────────────
# Qdrant and Ollama run via docker-compose by default.
# Set these only if running on non-default hosts.
# QDRANT_URL=http://127.0.0.1:6333
# OLLAMA_URL=http://127.0.0.1:11434/api/embeddings


# ── Observability (Langfuse) ─────────────────────────────────
# Optional. Traces and monitors agent execution.
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# LANGFUSE_HOST=https://cloud.langfuse.com


# ── MCP Server ───────────────────────────────────────────────
# Optional. Model Context Protocol server for tool access.
# MCP_HOST=127.0.0.1
# MCP_PORT=8765


# ── News Sender: Email (Resend) ──────────────────────────────
# Resend API key. Get key: https://resend.com
# RESEND_API_KEY=re_...

# Sender address (must be verified in Resend dashboard).
# RESEND_FROM=News Digest <news@yourdomain.com>

# Recipient address.
# RESEND_TO=you@example.com

# Enable email delivery.
# NEWS_SEND_EMAIL=true


# ── News Sender: Telegram ────────────────────────────────────
# Bot token from @BotFather. Create bot: https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=123456789:ABCDEF...

# Chat ID to send messages to. Get it from @userinfobot.
# TELEGRAM_CHAT_ID=123456789

# Enable Telegram delivery.
# NEWS_SEND_TELEGRAM=true


# ── News Sender: Discord ─────────────────────────────────────
# Webhook URL from channel settings → Integrations → Webhooks.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Enable Discord delivery.
# NEWS_SEND_DISCORD=true


# ── News Sender: File Output ─────────────────────────────────
# Optional. Write the report to a file after generation.
# If left empty, no file is written (stdout/log output only).
# A YYYY-MM-DD date prefix is automatically added to the filename.
# NEWS_OUTPUT_FILE=reports/latest-news.md  →  reports/2026-06-12-latest-news.md

# Optional. Write all log output to a plain-text file (no ANSI codes).
# Parallel to the colored stderr output.
# NEWS_LOG_FILE=logs/news-sender.log


# ── Domain Configuration ──────────────────────────────────────
# Force a research domain: ai, policy, biotech, finance, general.
# If left empty, domain is auto-detected from the query keywords.
# RESEARCH_DOMAIN=ai


# ── Debug Instrumentation ─────────────────────────────────────
# Set to 1/true/yes to enable verbose summarizer diagnostics:
#   - Raw context from vector store (char count, first 200 chars)
#   - Formatted evidence list before LLM call
#   - Raw LLM output before JSON parse
#   - Post-parse validation results
# DEBUG_SUMMARIZER=true
